{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "server.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testTimeout": 30000,
    "moduleNameMapper": {
      "^(\\.{1,2}/)*config/redis\\.js$": "<rootDir>/src/config/__mocks__/redis.js",
      "^(\\.{1,2}/)*config/socket\\.js$": "<rootDir>/src/config/__mocks__/socket.js"
    },
    "testEnvironmentOptions": {
      "env": {
        "NODE_ENV": "test"
      }
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@aws-sdk/s3-request-presigner": "^3.1055.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "rate-limiter-flexible": "^11.1.0",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
