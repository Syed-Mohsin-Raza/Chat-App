# ─── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/chatapp

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
